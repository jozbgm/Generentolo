# Gemini API Key — required (users can also set it in the app Settings)
VITE_API_KEY=your_gemini_api_key_here

# Google Custom Search API — optional, enables Google Search Grounding
# API key: https://developers.google.com/custom-search/v1/overview
# Search engine ID: https://programmablesearchengine.google.com/
VITE_GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
VITE_GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
