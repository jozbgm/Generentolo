@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* Brand Colors - Standardized for Single-Point Editing */
    --color-brand-yellow: #c8f23a; /* Main Accent */
    --color-brand-yellow-rgb: 200 242 58; /* RGB channels for opacity variants */
    --color-brand-magenta: #b5db35; /* Variant Accent */
    --color-brand-cyan: #e8e8e0;
    --color-brand-blue: #6b6b60;
    
    /* Legacy brand colors mapped to main accent for backward compatibility */
    --color-brand-purple: var(--color-brand-yellow);
    --color-brand-pink: var(--color-brand-yellow);
    
    /* Light Theme */
    --color-light-bg: #f0f0ed;
    --color-light-bg-rgb: 240 240 237;
    --color-light-surface: #f8f8f6;
    --color-light-surface-rgb: 248 248 246;
    --color-light-surface-accent: #ebebe8;
    --color-light-surface-accent-rgb: 235 235 232;
    --color-light-text: #111110;
    --color-light-text-muted: #6b6b60;
    --color-light-border: #dcdcd8;

    /* Dark Theme */
    --color-dark-bg: #1A1A1A; /* Antracite / Dark Anthracite */
    --color-dark-bg-rgb: 26 26 26;
    --color-dark-surface: #202020;
    --color-dark-surface-rgb: 32 32 32;
    --color-dark-surface-accent: #2A2A2A;
    --color-dark-surface-accent-rgb: 42 42 42;
    --color-dark-text: #F2F2F2;
    --color-dark-text-muted: #888888;
    --color-dark-border: #3A3A3A;
  }
}

/* Light Mode Overrides for Lime Text Readability */
html:not(.dark) .text-brand-yellow,
html:not(.dark) .text-brand-yellow\/80 {
  color: #4a5d16 !important; /* Dark Olive/Lime for stark contrast on white */
}
html:not(.dark) .hover\:text-brand-yellow:hover,
html:not(.dark) .group:hover .group-hover\:text-brand-yellow {
  color: #4a5d16 !important;
}
html:not(.dark) .peer:checked ~ div .peer-checked\:text-brand-yellow,
html:not(.dark) .peer:checked ~ span .peer-checked\:text-brand-yellow {
  color: #4a5d16 !important;
}


/* Prevent horizontal scroll on mobile */
html,
body {
  overflow-x: hidden;
  max-width: 100vw;
  position: relative;
}

body {
  overscroll-behavior-x: none;
}

/* Prevent text input zoom on iOS */
@media screen and (max-width: 768px) {

  input,
  textarea,
  select {
    font-size: 16px !important;
  }
}


/* Custom native select options */
select option {
  background-color: var(--color-dark-surface, #202020);
  color: var(--color-dark-text, #F2F2F2);
}

/* Force dark color-scheme on all selects globally to remove browser blue tint */
select {
  color-scheme: dark;
  background-color: var(--color-dark-surface, #202020);
  color: var(--color-dark-text, #F2F2F2);
}

.dark select {
  color-scheme: dark;
}

/* Override browser default blue focus outline on all interactive elements */
select:focus,
input:focus,
textarea:focus,
button:focus {
  outline: none !important;
  box-shadow: none !important;
}

/* Custom textarea resize handle styling */
textarea {
  scrollbar-width: thin;
  scrollbar-color: rgba(155, 155, 155, 0.25) transparent;
}

textarea::-webkit-scrollbar {
  width: 8px;
}

textarea::-webkit-scrollbar-track {
  background: transparent;
}

textarea::-webkit-scrollbar-thumb {
  background-color: rgba(155, 155, 155, 0.25);
  border-radius: 4px;
}

textarea::-webkit-scrollbar-thumb:hover {
  background-color: rgba(155, 155, 155, 0.4);
}

/* Prompt Library Modal Scrollbar */
.prompt-library-scroll {
  scrollbar-width: thin;
  scrollbar-color: rgba(200, 242, 58, 0.3) transparent;
}

.prompt-library-scroll::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

.prompt-library-scroll::-webkit-scrollbar-track {
  background: transparent;
}

.prompt-library-scroll::-webkit-scrollbar-thumb {
  background-color: rgba(200, 242, 58, 0.3);
  border-radius: 3px;
}

.prompt-library-scroll::-webkit-scrollbar-thumb:hover {
  background-color: rgba(200, 242, 58, 0.5);
}

/* Hide scrollbar for category tabs */
.hide-scrollbar {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.hide-scrollbar::-webkit-scrollbar {
  display: none;
}

/* --- v1.7.1: Global Custom Scrollbars --- */
* {
  scrollbar-width: thin;
  scrollbar-color: rgba(155, 155, 155, 0.2) transparent;
}

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background-color: rgba(155, 155, 155, 0.2);
  border-radius: 20px;
}

::-webkit-scrollbar-thumb:hover {
  background-color: rgba(155, 155, 155, 0.4);
}

/* Reusable utility for specific panels */
.custom-scrollbar::-webkit-scrollbar {
  width: 4px;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background-color: rgba(155, 155, 155, 0.15);
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background-color: rgba(155, 155, 155, 0.3);
}
/* 3D Transform Utilities for Perspective Studio */
.preserve-3d {
  transform-style: preserve-3d;
}

.perspective-800 {
  perspective: 800px;
}

/* Specific rotation helper for the wireframe sphere */
.rotate-y-15 { transform: rotateY(15deg); }
.rotate-y-30 { transform: rotateY(30deg); }
.rotate-y-45 { transform: rotateY(45deg); }
.rotate-y-60 { transform: rotateY(60deg); }
.rotate-y-75 { transform: rotateY(75deg); }
.rotate-y-90 { transform: rotateY(90deg); }
.rotate-y-105 { transform: rotateY(105deg); }
.rotate-y-120 { transform: rotateY(120deg); }
.rotate-y-135 { transform: rotateY(135deg); }
.rotate-y-150 { transform: rotateY(150deg); }
.rotate-y-165 { transform: rotateY(165deg); }

.rotate-x-90 { transform: rotateX(90deg); }

/* ============================================================
   THEME SYSTEM — Change palette from ONE place: index.css :root
   All color tokens are defined at the top as CSS variables.
   The .sweep-accent class below uses those same variables so
   the hover sweep on buttons automatically follows the theme.
   ============================================================ */

/* Reusable lime sweep gradient — references brand color variable */
.sweep-accent {
  background-image: linear-gradient(
    to right,
    transparent,
    var(--color-brand-yellow),
    transparent
  );
  opacity: 0;
  transition: opacity 0.7s ease-in-out, transform 0.7s ease-in-out;
  transform: translateX(-150%);
}

.group:hover .sweep-accent {
  opacity: 0.4;
  transform: translateX(150%);
}

